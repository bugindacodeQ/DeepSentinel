# DeepSentinel environment configuration
# Copy this file to .env and fill in your values

# Path to trained model weights
WEIGHTS_PATH=models/weights/efficientnet_b4.pth

# Model architecture (efficientnet_b4 or xception)
MODEL_NAME=efficientnet_b4

# Device: cpu or cuda
DEVICE=cpu

# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8000

# Hugging Face Hub (for uploading/downloading weights after training)
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here
HF_REPO_ID=your_username/DeepSentinel
